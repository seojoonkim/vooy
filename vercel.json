{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "vooy.ai"
        }
      ],
      "destination": "https://vooy.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.vooy.ai"
        }
      ],
      "destination": "https://vooy.com/$1",
      "permanent": true
    }
  ]
}
